# or
uv tool add abxpkg

# CLI
abxpkg --version
abxpkg version
abxpkg list
abxpkg install yt-dlp
abxpkg update yt-dlp
abxpkg uninstall yt-dlp
abxpkg load yt-dlp

# Select specific providers / re-order provider precedence
abxpkg install --binproviders=env,uv,pip,apt,brew prettier
