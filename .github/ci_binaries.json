{
  "properties": {
    "CI_BREW_BIN": {"default": "brew"},
    "CI_NIX_BIN": {"default": "nix"},
    "CI_NODE_BIN": {"default": "node"},
    "CI_NPM_BIN": {"default": "npm"},
    "CI_PNPM_BIN": {"default": "pnpm"},
    "CI_YARN_BIN": {"default": "yarn"},
    "CI_YARN_BERRY_BIN": {"default": "yarn-berry"},
    "CI_BUN_BIN": {"default": "bun"},
    "CI_DENO_BIN": {"default": "deno"},
    "CI_GO_BIN": {"default": "go"},
    "CI_CARGO_BIN": {"default": "cargo"},
    "CI_RUSTC_BIN": {"default": "rustc"},
    "CI_GEM_BIN": {"default": "gem"},
    "CI_GIT_BIN": {"default": "git"},
    "CI_UNZIP_BIN": {"default": "unzip"},
    "CI_ANSIBLE_BIN": {"default": "ansible"},
    "CI_ANSIBLE_PLAYBOOK_BIN": {"default": "ansible-playbook"},
    "CI_PYINFRA_BIN": {"default": "pyinfra"},
    "CI_UV_BIN": {"default": "uv"},
    "CI_APT_GET_BIN": {"default": "apt-get"},
    "CI_DPKG_BIN": {"default": "dpkg"},
    "CI_DOCKER_BIN": {"default": "docker"}
  },
  "docs_binaries": [
    {
      "name": "{CI_NODE_BIN}",
      "binproviders": ["env", "brew", "apt"],
      "min_version": "22.0.0",
      "overrides": {
        "brew": {"install_args": ["node"]},
        "apt": {"install_args": ["nodejs"]}
      }
    }
  ],
  "manager_binaries": [
    {"name": "{CI_BREW_BIN}", "binproviders": ["env"]},
    {"name": "{CI_NIX_BIN}", "binproviders": ["env"]}
  ],
  "node_npm_binaries": [
    {
      "name": "{CI_NODE_BIN}",
      "binproviders": ["env", "brew", "apt"],
      "min_version": "22.0.0",
      "overrides": {
        "brew": {"install_args": ["node"]},
        "apt": {"install_args": ["nodejs"]}
      }
    },
    {
      "name": "{CI_NPM_BIN}",
      "binproviders": ["env", "brew"],
      "overrides": {"brew": {"install_args": ["node"]}}
    }
  ],
  "pnpm_binaries": [
    {
      "name": "{CI_PNPM_BIN}",
      "binproviders": ["env", "npm"],
      "min_version": "10.19.0",
      "min_release_age": 0,
      "overrides": {
        "npm": {
          "install_root": "{ABXPKG_LIB_DIR}/npm/packages/pnpm",
          "install_args": ["pnpm@10.19.0"]
        }
      }
    }
  ],
  "yarn_binaries": [
    {
      "name": "{CI_YARN_BIN}",
      "binproviders": ["env", "npm"],
      "min_version": "1.22.22",
      "min_release_age": 0,
      "overrides": {
        "npm": {
          "install_root": "{ABXPKG_LIB_DIR}/npm/packages/yarn-classic",
          "install_args": ["yarn@1.22.22"]
        }
      }
    },
    {
      "name": "{CI_YARN_BERRY_BIN}",
      "binproviders": ["env", "npm"],
      "min_version": "4.13.0",
      "min_release_age": 0,
      "overrides": {
        "npm": {
          "install_root": "{ABXPKG_LIB_DIR}/npm/packages/yarn-berry",
          "alias_bin_dir": "{ABXPKG_LIB_DIR}/npm/aliases/yarn-berry/bin",
          "install_args": ["@yarnpkg/cli-dist@4.13.0"]
        }
      }
    }
  ],
  "bun_binaries": [
    {
      "name": "{CI_BUN_BIN}",
      "binproviders": ["env", "brew"],
      "overrides": {
        "brew": {
          "install_args": ["bun"],
          "postinstall_scripts": true
        }
      }
    }
  ],
  "deno_binaries": [
    {
      "name": "{CI_DENO_BIN}",
      "binproviders": ["env", "brew"],
      "min_version": "2.0.0",
      "overrides": {"brew": {"install_args": ["deno"]}}
    }
  ],
  "go_binaries": [
    {
      "name": "{CI_GO_BIN}",
      "binproviders": ["env", "brew"],
      "min_version": "1.25.0",
      "overrides": {"brew": {"install_args": ["go"]}}
    }
  ],
  "cargo_binaries": [
    {"name": "{CI_CARGO_BIN}", "binproviders": ["env", "brew"], "overrides": {"brew": {"install_args": ["rust"]}}},
    {"name": "{CI_RUSTC_BIN}", "binproviders": ["env", "brew"], "overrides": {"brew": {"install_args": ["rust"]}}}
  ],
  "gem_binaries": [
    {"name": "{CI_GEM_BIN}", "binproviders": ["env", "brew"], "overrides": {"brew": {"install_args": ["ruby"]}}}
  ],
  "host_utility_binaries": [
    {"name": "{CI_GIT_BIN}", "binproviders": ["env"]},
    {"name": "{CI_UNZIP_BIN}", "binproviders": ["env"]}
  ],
  "python_cli_binaries": [
    {"name": "{CI_ANSIBLE_BIN}", "binproviders": ["env"]},
    {"name": "{CI_ANSIBLE_PLAYBOOK_BIN}", "binproviders": ["env"]},
    {"name": "{CI_PYINFRA_BIN}", "binproviders": ["env"]},
    {"name": "{CI_UV_BIN}", "binproviders": ["env"]}
  ],
  "linux_binaries": [
    {"name": "{CI_APT_GET_BIN}", "binproviders": ["env"]},
    {"name": "{CI_DPKG_BIN}", "binproviders": ["env"]}
  ],
  "docker_binaries": [
    {"name": "{CI_DOCKER_BIN}", "binproviders": ["env"]}
  ]
}
